{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "incremental": true,
    "strictPropertyInitialization": false,
    "types": ["node"],
    "paths": {
      "@mms/shared": ["../../packages/shared/dist"]
    }
  },
  "include": ["src/**/*.ts"]
